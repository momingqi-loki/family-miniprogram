/* miniprogram/app.wxss - 全局样式与 TDesign 主题 */

/* ==================== TDesign 主题变量 ==================== */
page {
  /* 主色 */
  --td-brand-color: #FF8C00;
  --td-brand-color-light: #FFF3E0;
  --td-brand-color-dark: #E65100;
  
  /* 功能色 */
  --td-success-color: #4CAF50;
  --td-warning-color: #FFC107;
  --td-error-color: #FF5252;
  --td-info-color: #2196F3;
  
  /* 文字色 */
  --td-font-gray-1: #333333;
  --td-font-gray-2: #666666;
  --td-font-gray-3: #999999;
  --td-font-gray-4: #CCCCCC;
  
  /* 背景色 */
  --td-bg-color-page: #F5F5F5;
  --td-bg-color-container: #FFFFFF;
  --td-bg-color-gray: #F8F8F8;
  
  /* 边框 */
  --td-border-level-1: 1rpx solid #E5E5E5;
  --td-border-level-2: 1rpx solid #EEEEEE;
  
  /* 圆角 */
  --td-radius-small: 8rpx;
  --td-radius-medium: 16rpx;
  --td-radius-large: 24rpx;
  --td-radius-round: 999rpx;
  
  /* 阴影 */
  --td-shadow-1: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --td-shadow-2: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  
  /* 间距 */
  --td-spacer-1: 10rpx;
  --td-spacer-2: 20rpx;
  --td-spacer-3: 30rpx;
  --td-spacer-4: 40rpx;
  
  /* 字号 */
  --td-font-size-xs: 22rpx;
  --td-font-size-sm: 24rpx;
  --td-font-size-md: 28rpx;
  --td-font-size-lg: 32rpx;
  --td-font-size-xl: 36rpx;
  
  font-size: var(--td-font-size-md);
  color: var(--td-font-gray-1);
  background-color: var(--td-bg-color-page);
}

/* ==================== 兼容旧代码 ==================== */
page {
  --primary: var(--td-brand-color);
  --success: var(--td-success-color);
  --warning: var(--td-warning-color);
  --danger: var(--td-error-color);
  --info: var(--td-info-color);
  
  --text-primary: var(--td-font-gray-1);
  --text-secondary: var(--td-font-gray-2);
  --text-placeholder: var(--td-font-gray-3);
  
  --bg-page: var(--td-bg-color-page);
  --bg-card: var(--td-bg-color-container);
  --bg-gray: var(--td-bg-color-gray);
  
  --border-color: #E5E5E5;
  --border-radius: var(--td-radius-medium);
  --border-radius-lg: var(--td-radius-large);
  
  --shadow-sm: var(--td-shadow-1);
  --shadow-md: var(--td-shadow-2);
  
  --spacing-xs: var(--td-spacer-1);
  --spacing-sm: var(--td-spacer-2);
  --spacing-md: var(--td-spacer-3);
  --spacing-lg: var(--td-spacer-4);
}

/* ==================== 通用布局 ==================== */
.container {
  min-height: 100vh;
  padding: var(--spacing-sm);
  box-sizing: border-box;
}

.page-content {
  padding: var(--spacing-md);
}

/* ==================== 卡片组件 ==================== */
.card {
  background: var(--bg-card);
  border-radius: var(--border-radius-lg);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-sm);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.card-title {
  font-size: var(--td-font-size-lg);
  font-weight: bold;
  color: var(--text-primary);
}

/* ==================== 按钮 ==================== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: var(--td-font-size-md);
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, #FF6B00 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 0, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-secondary {
  background: var(--bg-card);
  color: var(--text-primary);
  border: 2rpx solid var(--border-color);
}

.btn-ghost {
  background: transparent;
  color: var(--primary);
}

.btn-block {
  width: 100%;
}

.btn-sm {
  height: 64rpx;
  font-size: var(--td-font-size-sm);
  border-radius: 32rpx;
}

/* ==================== 标签 ==================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: var(--td-font-size-xs);
}

.tag-primary { background: var(--td-brand-color-light); color: var(--primary); }
.tag-success { background: #E8F5E9; color: var(--success); }
.tag-warning { background: #FFF8E1; color: #F57C00; }
.tag-danger { background: #FFEBEE; color: var(--danger); }
.tag-info { background: #E3F2FD; color: var(--info); }

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--spacing-md);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.5;
}

.empty-text {
  font-size: var(--td-font-size-md);
  color: var(--text-placeholder);
  text-align: center;
}

/* ==================== 动画 ==================== */
.fade-in {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.slide-up {
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(100%); }
  to { opacity: 1; transform: translateY(0); }
}

/* ==================== 工具类 ==================== */
.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

.text-primary { color: var(--primary); }
.text-secondary { color: var(--text-secondary); }
.text-placeholder { color: var(--text-placeholder); }
.text-success { color: var(--success); }
.text-danger { color: var(--danger); }

.text-sm { font-size: var(--td-font-size-sm); }
.text-md { font-size: var(--td-font-size-md); }
.text-lg { font-size: var(--td-font-size-lg); }
.text-xl { font-size: var(--td-font-size-xl); }

.font-bold { font-weight: bold; }

.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-center { align-items: center; justify-content: center; }
.flex-between { justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }

.gap-xs { gap: var(--spacing-xs); }
.gap-sm { gap: var(--spacing-sm); }
.gap-md { gap: var(--spacing-md); }

.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }

.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
