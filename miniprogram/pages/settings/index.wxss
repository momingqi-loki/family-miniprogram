/* pages/settings/index.wxss - 设置页面样式 */
.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 0;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(135deg, #FF8C00 0%, #FF6B00 100%);
}

.user-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-avatar image {
  width: 100%;
  height: 100%;
  background: #F0F0F0;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.5);
  text-align: center;
  padding: 8rpx 0;
  font-size: 20rpx;
  color: #fff;
}

.user-info {
  flex: 1;
  margin-left: 30rpx;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.user-role {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.user-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 分区 */
.section {
  padding: 40rpx 30rpx 0;
}

.section-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

/* 菜单列表 */
.menu-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #F8F8F8;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCC;
}

.menu-badge {
  background: #FF8C00;
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

/* 开关 */
.switch {
  width: 96rpx;
  height: 52rpx;
  background: #E5E5E5;
  border-radius: 26rpx;
  position: relative;
  transition: all 0.3s;
}

.switch.active {
  background: #4CAF50;
}

.switch-thumb {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 44rpx;
  height: 44rpx;
  background: #fff;
  border-radius: 22rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s;
}

.switch.active .switch-thumb {
  transform: translateX(44rpx);
}

/* 危险操作 */
.menu-item.danger .menu-text {
  color: #FF5252;
}

.btn-clear {
  background: none;
  border: none;
  outline: none;
  width: 100%;
  text-align: left;
}

.btn-clear::after {
  border: none;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 60rpx 0 30rpx;
  font-size: 24rpx;
  color: #CCC;
}

/* 安全区 */
.safe-bottom {
  height: 120rpx;
}
