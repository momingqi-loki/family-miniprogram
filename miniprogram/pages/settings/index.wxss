/* pages/settings/index.wxss */
.container {
  padding: 20rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  background-color: #FF8C00;
  color: #FFFFFF;
  font-size: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.user-role {
  font-size: 24rpx;
  color: #999999;
}

.user-action {
  padding: 10rpx 20rpx;
  background-color: #F5F5F5;
  border-radius: 24rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666666;
}

/* 模块 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  margin-bottom: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

/* 卡片 */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.family-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.family-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.family-count {
  font-size: 24rpx;
  color: #999999;
}

.family-create {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
}

.create-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.create-text {
  font-size: 28rpx;
  color: #666666;
}

/* 成员列表 */
.member-list {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  background-color: #FF8C00;
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.member-name {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.member-role {
  font-size: 24rpx;
  padding: 5rpx 15rpx;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  color: #666666;
}

.section-action {
  margin-top: 20rpx;
  text-align: center;
}

.section-action .action-text {
  font-size: 28rpx;
  color: #FF8C00;
}

/* 设置列表 */
.setting-list {
  background-color: #FFFFFF;
  border-radius: 16rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: #333333;
}

.setting-arrow {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* 退出登录 */
.logout-section {
  margin-top: 60rpx;
}

.btn-logout {
  background-color: #FFFFFF;
  color: #F44336;
  border: none;
  border-radius: 16rpx;
  padding: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-logout::after {
  border: none;
}
