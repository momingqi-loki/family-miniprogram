<!-- pages/settings/index.wxml - 设置页面 -->
<view class="container">
  <!-- 用户卡片 -->
  <view class="user-card">
    <view class="user-avatar" bindtap="onEditProfile">
      <image src="{{userInfo.avatar || '/miniprogram/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="avatar-edit">
        <text>编辑</text>
      </view>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickname || '未设置昵称'}}</text>
      <text class="user-role">{{familyInfo ? familyInfo.name : '未加入家庭'}}</text>
    </view>
    <view class="user-arrow">›</view>
  </view>

  <!-- 家庭管理 -->
  <view class="section">
    <view class="section-title">家庭管理</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="onFamilyInfo">
        <view class="menu-left">
          <text class="menu-icon">👨‍👩‍👧‍👦</text>
          <text class="menu-text">家庭信息</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onInviteCode">
        <view class="menu-left">
          <text class="menu-icon">📢</text>
          <text class="menu-text">邀请成员</text>
        </view>
        <view class="menu-badge" wx:if="{{inviteCode}}">{{inviteCode}}</view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onFamilyMembers">
        <view class="menu-left">
          <text class="menu-icon">👥</text>
          <text class="menu-text">成员列表</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 通用设置 -->
  <view class="section">
    <view class="section-title">通用设置</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="onNotifications">
        <view class="menu-left">
          <text class="menu-icon">🔔</text>
          <text class="menu-text">通知设置</text>
        </view>
        <view class="switch {{notificationsEnabled ? 'active' : ''}}" bindtap="onToggleNotification">
          <view class="switch-thumb"></view>
        </view>
      </view>
      <view class="menu-item" bindtap="onPrivacy">
        <view class="menu-left">
          <text class="menu-icon">🔒</text>
          <text class="menu-text">隐私设置</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onAbout">
        <view class="menu-left">
          <text class="menu-icon">ℹ️</text>
          <text class="menu-text">关于我们</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 账号操作 -->
  <view class="section">
    <view class="section-title">账号</view>
    <view class="menu-list">
      <button class="menu-item btn-clear" open-type="contact">
        <view class="menu-left">
          <text class="menu-icon">💬</text>
          <text class="menu-text">联系客服</text>
        </view>
        <text class="menu-arrow">›</text>
      </button>
      <view class="menu-item danger" bindtap="onLogout">
        <view class="menu-left">
          <text class="menu-icon">🚪</text>
          <text class="menu-text">退出登录</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>家庭管理小程序 v1.0.0</text>
  </view>

  <!-- 安全区 -->
  <view class="safe-bottom"></view>
</view>
