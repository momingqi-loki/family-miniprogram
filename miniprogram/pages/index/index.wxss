/* pages/index/index.wxss - 首页样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8F0 0%, #FFF 100%);
  padding: 0;
}

/* 顶部欢迎区域 */
.header-section {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 80rpx 40rpx 40rpx;
  background: linear-gradient(135deg, #FF8C00 0%, #FF6B00 100%);
  border-radius: 0 0 48rpx 48rpx;
}

.greeting-area {
  flex: 1;
}

.greeting {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.wave {
  font-size: 48rpx;
  animation: wave 1s ease-in-out infinite;
}

@keyframes wave {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(20deg); }
  75% { transform: rotate(-15deg); }
}

.greeting-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.date-text {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.weather-hint {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.weather-icon {
  font-size: 40rpx;
}

/* 统计卡片 */
.stats-row {
  display: flex;
  gap: 20rpx;
  margin: -30rpx 30rpx 0;
  position: relative;
  z-index: 10;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF8C00;
  line-height: 1;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 内容区域 */
.section {
  padding: 40rpx 30rpx 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 任务列表 */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s;
}

.task-card:active {
  transform: scale(0.98);
}

.task-card.completed {
  opacity: 0.6;
}

.task-card.completed .task-title {
  text-decoration: line-through;
  color: #999;
}

.task-checkbox {
  margin-right: 24rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #E5E5E5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.checkbox.checked {
  background: #4CAF50;
  border-color: #4CAF50;
  color: #fff;
  font-size: 24rpx;
}

.task-content {
  flex: 1;
}

.task-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.task-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 10rpx;
}

.task-priority {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.priority-high { background: #FFEBEE; color: #FF5252; }
.priority-medium { background: #FFF3E0; color: #FF9800; }
.priority-low { background: #E3F2FD; color: #2196F3; }

.task-assignee {
  font-size: 22rpx;
  color: #999;
}

/* 日程列表 */
.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.schedule-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.schedule-time {
  width: 100rpx;
  text-align: center;
}

.time-text {
  font-size: 24rpx;
  color: #FF8C00;
  font-weight: 500;
}

.schedule-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.schedule-title {
  font-size: 28rpx;
  color: #333;
}

.tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  width: fit-content;
}

.tag-meeting { background: #E3F2FD; color: #1976D2; }
.tag-reminder { background: #FFF3E0; color: #FF8C00; }
.tag-activity { background: #E8F5E9; color: #4CAF50; }
.tag-other { background: #F5F5F5; color: #666; }

.schedule-arrow {
  font-size: 32rpx;
  color: #CCC;
  margin-left: 16rpx;
}

/* 快捷操作 */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 10rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.quick-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.quick-label {
  font-size: 22rpx;
  color: #666;
}

/* 家庭成员 */
.member-scroll {
  display: flex;
  gap: 20rpx;
  overflow-x: auto;
  padding-bottom: 20rpx;
}

.member-scroll::-webkit-scrollbar {
  display: none;
}

.member-card {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  min-width: 140rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFB74D 0%, #FF8C00 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  position: relative;
}

.member-avatar.online::after {
  content: '';
  position: absolute;
  right: 0;
  bottom: 0;
  width: 20rpx;
  height: 20rpx;
  background: #4CAF50;
  border: 3rpx solid #fff;
  border-radius: 50%;
}

.member-name {
  font-size: 24rpx;
  color: #333;
  margin-top: 16rpx;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  background: #CCC;
  border-radius: 50%;
}

.status-dot.online {
  background: #4CAF50;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  background: #fff;
  border-radius: 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 安全区 */
.safe-bottom {
  height: 120rpx;
}
