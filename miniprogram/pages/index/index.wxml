<!--pages/index/index.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <text class="greeting">👋 早上好，{{userInfo.nickname}}</text>
    <text class="date">{{todayDate}}</text>
  </view>

  <!-- 今日概览 -->
  <view class="section">
    <view class="section-title">
      <text class="title">今日概览</text>
    </view>

    <!-- 今日待办 -->
    <view class="card" wx:if="{{todayTasks.length > 0}}">
      <view class="card-header">
        <text class="card-title">📋 今日待办 ({{todayTasks.length}})</text>
      </view>
      <view class="task-list">
        <view
          class="task-item"
          wx:for="{{todayTasks}}"
          wx:key="id"
          bindtap="onTaskClick"
          data-id="{{item.id}}"
        >
          <text class="task-title">{{item.title}}</text>
          <text class="task-assignee">← {{item.assigneeName}}</text>
        </view>
      </view>
    </view>

    <!-- 今日日程 -->
    <view class="card" wx:if="{{todayEvents.length > 0}}">
      <view class="card-header">
        <text class="card-title">📅 今日日程 ({{todayEvents.length}})</text>
      </view>
      <view class="event-list">
        <view
          class="event-item"
          wx:for="{{todayEvents}}"
          wx:key="id"
          bindtap="onEventClick"
          data-id="{{item.id}}"
        >
          <text class="event-time">{{item.startTime}}</text>
          <text class="event-title">{{item.title}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="navigateToPlan">
      <text class="action-icon">🌴</text>
      <text class="action-label">旅游规划</text>
    </view>
    <view class="action-item" bindtap="navigateToTask">
      <text class="action-icon">✅</text>
      <text class="action-label">任务管理</text>
    </view>
    <view class="action-item" bindtap="navigateToSchedule">
      <text class="action-icon">📅</text>
      <text class="action-label">日程安排</text>
    </view>
    <view class="action-item" bindtap="navigateToSettings">
      <text class="action-icon">⚙️</text>
      <text class="action-label">设置</text>
    </view>
  </view>

  <!-- 家庭成员状态 -->
  <view class="section">
    <view class="section-title">
      <text class="title">家庭成员状态</text>
    </view>
    <view class="member-list">
      <view class="member-item" wx:for="{{familyMembers}}" wx:key="id">
        <text class="member-avatar">{{item.nickname.substring(0, 1)}}</text>
        <text class="member-name">{{item.nickname}}</text>
        <text class="member-status">{{item.online ? '在线' : '离线'}}</text>
      </view>
    </view>
  </view>
</view>
