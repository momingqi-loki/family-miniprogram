/* pages/family/join.wxss - 加入家庭页面样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8F0 0%, #FFFFFF 100%);
  padding: 60rpx 40rpx;
}

/* 头部 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 80rpx;
}

.header .icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

/* Tab 切换 */
.tabs {
  display: flex;
  background: #F5F5F5;
  border-radius: 40rpx;
  padding: 8rpx;
  margin-bottom: 50rpx;
}

.tab {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  border-radius: 32rpx;
  transition: all 0.3s;
}

.tab.active {
  background: #FF8C00;
  color: #fff;
  font-weight: 500;
}

/* 表单 */
.form-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.input {
  height: 88rpx;
  padding: 0 30rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.code-input {
  text-align: center;
  font-size: 36rpx;
  letter-spacing: 8rpx;
  font-weight: bold;
}

.textarea {
  width: 100%;
  height: 160rpx;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 分隔文本 */
.divider-text {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin: 30rpx 0;
}

/* 扫码按钮 */
.btn-scan {
  width: 100%;
  height: 88rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-scan .icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.btn-scan text {
  font-size: 28rpx;
  color: #333;
}

/* 按钮 */
.btn-create, .btn-join {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF8C00 0%, #FF6B00 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  margin-top: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 0, 0.3);
}

.btn-create:active, .btn-join:active {
  transform: scale(0.98);
  opacity: 0.9;
}
