/* pages/plan/index.wxss */
.container {
  padding: 20rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 标签切换 */
.tabs {
  display: flex;
  margin-bottom: 30rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 10rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab.active {
  background-color: #FF8C00;
  color: #FFFFFF;
  font-weight: bold;
}

/* 标签内容 */
.tab-content {
  animation: fadeIn 0.3s ease-in;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.btn-create {
  background-color: #FF8C00;
  color: #FFFFFF;
  border: none;
  border-radius: 24rpx;
  padding: 10rpx 30rpx;
  font-size: 24rpx;
}

.btn-create::after {
  border: none;
}

/* 列表 */
.list {
  padding-bottom: 20rpx;
}

/* 卡片 */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.trip-emoji,
.holiday-emoji {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.trip-info,
.holiday-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.trip-title,
.holiday-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.trip-date,
.holiday-date {
  font-size: 24rpx;
  color: #999999;
}

.card-body {
  margin-bottom: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.info-item {
  font-size: 24rpx;
  color: #666666;
  padding: 10rpx 20rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.status {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  color: #FFFFFF;
  background-color: #FFC107;
}

.type {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  background-color: #2196F3;
  color: #FFFFFF;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #CCCCCC;
}
