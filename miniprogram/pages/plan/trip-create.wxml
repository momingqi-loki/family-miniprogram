<!--pages/plan/trip-create.wxml-->
<view class="container">
  <view class="header">
    <text class="title">新建旅游计划</text>
  </view>

  <view class="form">
    <!-- 目的地 -->
    <view class="form-item">
      <text class="label">目的地 *</text>
      <input
        class="input"
        placeholder="请输入旅游目的地"
        bindinput="bindDestinationInput"
        value="{{form.destination}}"
      />
    </view>

    <!-- 日期 -->
    <view class="form-item">
      <text class="label">开始日期 *</text>
      <picker
        mode="date"
        value="{{form.startDate}}"
        bindchange="bindStartDateChange"
      >
        <view class="picker">
          {{form.startDate || '请选择开始日期'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">结束日期</text>
      <picker
        mode="date"
        value="{{form.endDate}}"
        bindchange="bindEndDateChange"
      >
        <view class="picker">
          {{form.endDate || '请选择结束日期'}}
        </view>
      </picker>
    </view>

    <!-- 参与人 -->
    <view class="form-item">
      <text class="label">参与人 *</text>
      <view class="participants-list">
        <view
          class="participant-item {{item.selected ? 'selected' : ''}}"
          wx:for="{{familyMembers}}"
          wx:key="id"
          bindtap="selectParticipant"
          data-index="{{index}}"
        >
          <text class="participant-avatar">{{item.nickname.substring(0, 1)}}</text>
          <text class="participant-name">{{item.nickname}}</text>
          <text class="participant-check">{{item.selected ? '✓' : ''}}</text>
        </view>
      </view>
    </view>

    <!-- 预算 -->
    <view class="form-item">
      <text class="label">预算（元）</text>
      <input
        class="input"
        type="digit"
        placeholder="请输入预算"
        bindinput="bindBudgetInput"
        value="{{form.budget}}"
      />
    </view>

    <!-- 备注 -->
    <view class="form-item">
      <text class="label">备注</text>
      <textarea
        class="textarea"
        placeholder="请输入备注"
        bindinput="bindRemarkInput"
        value="{{form.remark}}"
        maxlength="200"
      />
    </view>

    <!-- 按钮 -->
    <view class="form-actions">
      <button class="btn-cancel" bindtap="cancel">取消</button>
      <button class="btn-submit" bindtap="submitForm">保存</button>
    </view>
  </view>
</view>
