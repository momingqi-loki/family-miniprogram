/* pages/plan/trip-create.wxss */
.container {
  padding: 20rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 头部 */
.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

/* 表单 */
.form {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
}

/* 表单项 */
.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #FFFFFF;
}

.textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 20rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #FFFFFF;
}

/* 选择器 */
.picker {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
}

/* 参与人列表 */
.participants-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #F5F5F5;
  border-radius: 24rpx;
  border: 2rpx solid #E0E0E0;
  transition: all 0.3s;
}

.participant-item.selected {
  background-color: #FF8C00;
  border-color: #FF8C00;
  color: #FFFFFF;
}

.participant-avatar {
  width: 48rpx;
  height: 48rpx;
  background-color: #FFFFFF;
  color: #FF8C00;
  font-size: 24rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
}

.participant-item.selected .participant-avatar {
  color: #FFFFFF;
}

.participant-name {
  font-size: 24rpx;
  color: #333333;
}

.participant-item.selected .participant-name {
  color: #FFFFFF;
}

.participant-check {
  font-size: 24rpx;
  margin-left: 10rpx;
  color: #4CAF50;
}

/* 按钮 */
.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-cancel,
.btn-submit {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-cancel {
  background-color: #F5F5F5;
  color: #666666;
  border: none;
}

.btn-submit {
  background-color: #FF8C00;
  color: #FFFFFF;
  border: none;
}

.btn-cancel::after,
.btn-submit::after {
  border: none;
}
