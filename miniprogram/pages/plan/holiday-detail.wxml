<view class="container">
  <view class="loading" wx:if="{{loading}}">加载中...</view>
  
  <view class="detail-content" wx:if="{{holiday && !loading}}">
    <view class="header">
      <view class="title">{{holiday.name}}</view>
      <view class="date">{{holiday.date}}</view>
    </view>
    
    <view class="section">
      <view class="section-title">节日类型</view>
      <view class="tag">{{holiday.type}}</view>
    </view>
    
    <view class="section" wx:if="{{holiday.description}}">
      <view class="section-title">描述</view>
      <view class="description">{{holiday.description}}</view>
    </view>
    
    <view class="actions">
      <button class="btn-edit" bindtap="editHoliday">编辑</button>
      <button class="btn-delete" bindtap="deleteHoliday">删除</button>
    </view>
  </view>
</view>
