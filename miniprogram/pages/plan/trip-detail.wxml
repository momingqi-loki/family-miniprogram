<!-- pages/plan/trip-detail.wxml - 旅行详情页 -->
<view class="container">
  <view class="loading" wx:if="{{loading}}">加载中...</view>
  
  <view class="detail-content" wx:if="{{trip && !loading}}">
    <!-- 头部区域 -->
    <view class="header">
      <view class="cover">
        <view class="cover-placeholder">
          <text class="icon">✈️</text>
        </view>
      </view>
      <view class="status-bar">
        <text class="status {{trip.status}}">
          {{trip.status === 'planning' ? '规划中' : trip.status === 'in-progress' ? '进行中' : '已完成'}}
        </text>
      </view>
    </view>

    <!-- 旅行信息 -->
    <view class="info-card">
      <view class="trip-title">{{trip.name}}</view>
      
      <view class="info-row">
        <view class="info-item">
          <text class="label">目的地</text>
          <text class="value">{{trip.destination}}</text>
        </view>
        <view class="info-item">
          <text class="label">预计天数</text>
          <text class="value">{{trip.days || 0}} 天</text>
        </view>
      </view>

      <view class="info-row">
        <view class="info-item">
          <text class="label">出发日期</text>
          <text class="value">{{trip.startDate}}</text>
        </view>
        <view class="info-item">
          <text class="label">预算</text>
          <text class="value">¥{{trip.budget || 0}}</text>
        </view>
      </view>
    </view>

    <!-- 参与成员 -->
    <view class="info-card">
      <view class="card-title">参与成员</view>
      <view class="members">
        <view class="member" wx:for="{{trip.members}}" wx:key="_id">
          <view class="avatar">{{item.name ? item.name[0] : '?'}}</view>
          <view class="name">{{item.name || '未知'}}</view>
        </view>
      </view>
    </view>

    <!-- 旅行描述 -->
    <view class="info-card" wx:if="{{trip.description}}">
      <view class="card-title">旅行计划</view>
      <view class="description">{{trip.description}}</view>
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <button class="btn-edit" bindtap="editTrip">编辑行程</button>
      <button class="btn-delete" bindtap="deleteTrip">删除</button>
    </view>
  </view>
</view>
