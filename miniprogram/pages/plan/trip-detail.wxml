<!--pages/plan/trip-detail.wxml-->
<view class="container" wx:if="{{!loading}}">
  <view class="header">
    <text class="title">🌴 {{trip.destination}}</text>
  </view>

  <!-- 基本信息 -->
  <view class="card">
    <view class="card-title">基本信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="label">📅 开始日期</text>
        <text class="value">{{trip.startDate}}</text>
      </view>
      <view class="info-item" wx:if="{{trip.endDate}}">
        <text class="label">📅 结束日期</text>
        <text class="value">{{trip.endDate}}</text>
      </view>
      <view class="info-item">
        <text class="label">👥 参与人</text>
        <text class="value">{{trip.participantCount}}人</text>
      </view>
      <view class="info-item" wx:if="{{trip.budget}}">
        <text class="label">💰 预算</text>
        <text class="value">¥{{trip.budget}}</text>
      </view>
    </view>
  </view>

  <!-- 进度跟踪 -->
  <view class="card" wx:if="{{trip.status}}">
    <view class="card-title">进度跟踪</view>
    <view class="status-progress">
      <view class="progress-item {{trip.status === 'planning' ? 'active' : ''}}">
        <text class="progress-icon">⏳</text>
        <text class="progress-text">规划中</text>
      </view>
      <view class="progress-item {{trip.status === 'confirmed' ? 'active' : ''}}">
        <text class="progress-icon">🚀</text>
        <text class="progress-text">行程已确定</text>
      </view>
      <view class="progress-item {{trip.status === 'completed' ? 'active' : ''}}">
        <text class="progress-icon">✅</text>
        <text class="progress-text">已完成</text>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="card" wx:if="{{trip.remark}}">
    <view class="card-title">备注</view>
    <text class="remark-text">{{trip.remark}}</text>
  </view>

  <!-- 操作按钮 -->
  <view class="actions">
    <button class="btn-edit" bindtap="editTrip">编辑</button>
    <button class="btn-delete" bindtap="deleteTrip">删除</button>
  </view>
</view>

<view class="loading" wx:if="{{loading}}">
  <text>加载中...</text>
</view>
