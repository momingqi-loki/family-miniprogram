/* pages/plan/holiday-create.wxss - 创建节日页面样式 */
.container {
  padding: 30rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

.form {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.required {
  color: #FF4444;
  margin-right: 4rpx;
}

.input {
  height: 88rpx;
  padding: 0 30rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: 1rpx solid transparent;
  transition: all 0.3s;
}

.input:focus {
  border-color: #FF8C00;
  background: #fff;
}

.picker {
  height: 88rpx;
  padding: 0 30rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 88rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1rpx solid transparent;
}

.picker.placeholder {
  color: #999;
}

.picker:active {
  background: #F0F0F0;
}

.arrow {
  font-size: 32rpx;
  color: #CCC;
}

/* 类型选择网格 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 10rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.type-item.active {
  background: #FFF5E6;
  border-color: #FF8C00;
}

.type-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.type-name {
  font-size: 22rpx;
  color: #666;
}

.type-item.active .type-name {
  color: #FF8C00;
  font-weight: 500;
}

/* 单选按钮组 */
.radio-group {
  display: flex;
  gap: 20rpx;
}

.radio-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.radio-item.active {
  background: #FFF5E6;
  border-color: #FF8C00;
  color: #FF8C00;
}

.radio-dot {
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  margin-right: 12rpx;
  box-sizing: border-box;
}

.radio-item.active .radio-dot {
  background: currentColor;
}

/* 文本域 */
.textarea {
  width: 100%;
  height: 200rpx;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: 1rpx solid transparent;
  box-sizing: border-box;
  transition: all 0.3s;
}

.textarea:focus {
  border-color: #FF8C00;
  background: #fff;
}

/* 提交按钮 */
.submit-btn {
  margin-top: 60rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #FF8C00 0%, #FF6B00 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}
