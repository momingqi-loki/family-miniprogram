.container {
  padding: 20rpx;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

.detail-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-tag.todo { background: #f0f0f0; color: #666; }
.status-tag.inprogress { background: #FFF3E0; color: #FF8C00; }
.status-tag.completed { background: #E8F5E9; color: #4CAF50; }

.section {
  margin-bottom: 20rpx;
}

.label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
}

.priority {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.priority.low { background: #E3F2FD; color: #2196F3; }
.priority.medium { background: #FFF3E0; color: #FF8C00; }
.priority.high { background: #FFEBEE; color: #F44336; }

.description {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-toggle, .btn-edit, .btn-delete {
  width: 100%;
  padding: 20rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.btn-toggle { background: #4CAF50; color: #fff; }
.btn-edit { background: #FF8C00; color: #fff; }
.btn-delete {
  background: #fff;
  color: #ff4444;
  border: 1rpx solid #ff4444;
}
