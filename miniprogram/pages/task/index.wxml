<!--pages/task/index.wxml-->
<view class="container">
  <!-- 标签切换 -->
  <view class="tabs">
    <view
      class="tab {{activeTab === 'todo' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="todo"
    >
      🔴 待办
    </view>
    <view
      class="tab {{activeTab === 'inprogress' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="inprogress"
    >
      🟡 进行中
    </view>
    <view
      class="tab {{activeTab === 'completed' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="completed"
    >
      🟢 已完成
    </view>
  </view>

  <!-- 任务列表 -->
  <view class="task-list">
    <view
      class="task-card"
      wx:for="{{tasks}}"
      wx:key="id"
    >
      <view class="task-header" bindtap="viewTask" data-id="{{item.id}}">
        <text class="task-title">{{item.title}}</text>
        <text class="task-assignee">← {{item.assigneeName}}</text>
      </view>
      <view class="task-body" bindtap="viewTask" data-id="{{item.id}}">
        <text class="task-type">{{item.typeText}}</text>
        <text class="task-deadline" wx:if="{{item.deadline}}">
          📅 {{item.deadline}}
        </text>
      </view>
      <view class="task-footer" wx:if="{{activeTab !== 'completed'}}">
        <button
          class="btn-complete"
          bindtap="completeTask"
          data-id="{{item.id}}"
        >
          完成
        </button>
      </view>
    </view>

    <view class="empty" wx:if="{{tasks.length === 0}}">
      <text class="empty-text">暂无任务</text>
    </view>
  </view>

  <!-- 新建按钮 -->
  <view class="fab" bindtap="createTask">
    <text class="fab-icon">+</text>
  </view>
</view>
