/* pages/task/index.wxss */
.container {
  padding: 20rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 标签切换 */
.tabs {
  display: flex;
  margin-bottom: 30rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 10rpx;
  overflow-x: auto;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: #666666;
  border-radius: 12rpx;
  white-space: nowrap;
  transition: all 0.3s;
}

.tab.active {
  background-color: #FF8C00;
  color: #FFFFFF;
  font-weight: bold;
}

/* 任务列表 */
.task-list {
  padding-bottom: 100rpx;
}

.task-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.task-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.task-assignee {
  font-size: 24rpx;
  color: #FF8C00;
  margin-left: 20rpx;
}

.task-body {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.task-type {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  color: #666666;
}

.task-deadline {
  font-size: 24rpx;
  color: #999999;
}

.task-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.btn-complete {
  background-color: #4CAF50;
  color: #FFFFFF;
  border: none;
  border-radius: 24rpx;
  padding: 10rpx 30rpx;
  font-size: 24rpx;
}

.btn-complete::after {
  border: none;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  bottom: 100rpx;
  right: 40rpx;
  width: 120rpx;
  height: 120rpx;
  background-color: #FF8C00;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 0, 0.3);
  z-index: 1000;
}

.fab-icon {
  font-size: 60rpx;
  color: #FFFFFF;
  line-height: 1;
}
