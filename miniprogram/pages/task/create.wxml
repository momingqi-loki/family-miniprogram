<view class="container">
  <view class="form">
    <view class="form-item">
      <view class="label">任务标题</view>
      <input 
        class="input" 
        placeholder="请输入任务标题"
        value="{{task.title}}"
        bindinput="onTitleInput"
      />
    </view>

    <view class="form-item">
      <view class="label">任务描述</view>
      <textarea 
        class="textarea"
        placeholder="请输入任务描述"
        value="{{task.description}}"
        bindinput="onDescriptionInput"
      />
    </view>

    <view class="form-item">
      <view class="label">优先级</view>
      <picker 
        mode="selector" 
        range="{{priorities}}"
        bindchange="onPriorityChange"
      >
        <view class="picker">
          {{task.priority === 'low' ? '低' : task.priority === 'medium' ? '中' : '高'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="label">截止日期</view>
      <picker 
        mode="date" 
        value="{{task.deadline}}"
        bindchange="onDeadlineChange"
      >
        <view class="picker">
          {{task.deadline || '请选择日期'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="label">负责人</view>
      <picker 
        mode="selector" 
        range="{{familyMembers}}"
        range-key="name"
        bindchange="onAssigneeChange"
      >
        <view class="picker">
          {{task.assigneeName || '请选择负责人'}}
        </view>
      </picker>
    </view>

    <button class="submit-btn" bindtap="submit">保存</button>
  </view>
</view>
